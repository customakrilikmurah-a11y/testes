rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. PUBLIC ACCESS CODES (Hanya untuk pengecekan login)
    match /accessCodes/{code} {
      allow get: if true;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['displayName'])
        && data.displayName is string && data.displayName.size() <= 100
        && (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'createdBy', 'createdAt', 'members'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && data.members is list && data.members.size() > 0 && data.members.size() <= 100
        && (data.members.hasAny([request.auth.uid]));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'createdAt'])
        && data.text is string && data.text.size() > 0 && data.text.size() <= 5000
        && data.senderId == request.auth.uid
        && data.createdAt == request.time
        && data.senderName is string && data.senderName.size() <= 100;
    }

    // --- Collection Rules ---

    // 2. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
    }

    // 3. Chat Rooms
    match /rooms/{roomId} {
      function isMember() {
        return isSignedIn() && exists(/databases/$(database)/documents/rooms/$(roomId)) 
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.members.hasAny([request.auth.uid]);
      }

      // Anyone signed in can SEE and LIST rooms (Access Code is the gate)
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming());
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;

      // 4. Messages (Sub-collection)
      match /messages/{messageId} {
        // Messages are accessible if the user is logged in
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming());
        allow delete: if isSignedIn(); 
      }
    }

    // 0. Global Safety Net (Tutup sisa akses lainnya)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
