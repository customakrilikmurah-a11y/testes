{
  "entities": {
    "Room": {
      "title": "Chat Room",
      "description": "A container for chat messages between users.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the chat room."
        },
        "description": {
          "type": "string",
          "description": "A short description of the room purpose."
        },
        "createdBy": {
          "type": "string",
          "description": "User ID of the room creator."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the room was created."
        },
        "members": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user IDs who have access to this room."
        }
      },
      "required": ["name", "createdBy", "createdAt", "members"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message sent within a room.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "senderId": {
          "type": "string",
          "description": "User ID of the sender."
        },
        "senderName": {
          "type": "string",
          "description": "Display name of the sender."
        },
        "senderPhoto": {
          "type": "string",
          "description": "Profile picture URL of the sender."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["text", "senderId", "senderName", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Public profile information for a user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email"]
    },
    "AccessCode": {
      "title": "Access Code",
      "description": "Pre-defined codes for users to enter the app.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["displayName"]
    }
  },
  "firestore": {
    "/accessCodes/{code}": {
      "schema": "AccessCode",
      "description": "Valid access codes and their associated profiles."
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of chat rooms."
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Sub-collection of messages for a specific room."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
